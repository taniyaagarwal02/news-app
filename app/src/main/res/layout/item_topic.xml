<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="50dp"
    app:cardUseCompatPadding="false"
    app:cardElevation="0dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/dot_inactive">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Placeholder background color; you can later load images -->
        <ImageView
            android:id="@+id/topicImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:background="@color/purple_50" />

        <TextView
            android:id="@+id/topicName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Topic"
            android:textColor="@android:color/white"
            android:textStyle="bold" />

        <!-- Small check indicator in the corner -->
        <ImageView
            android:id="@+id/topicCheck"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:visibility="gone"
            android:src="@drawable/ic_check_circle"
            android:tint="@color/accent_blue" />

    </FrameLayout>

</com.google.android.material.card.MaterialCardView>

